# 複製此檔為 .env，並填入你自己的資料，.env 不會被上傳到 GitHub
# 兩邊金鑰都可以只填一邊，position_poller.py 會自動略過沒填的交易所

# ---- Gate.io（現貨 + 合約都用這組）----
GATE_API_KEY=你的Gate_API_Key
GATE_API_SECRET=你的Gate_API_Secret
GATE_TESTNET=false

# 要輪詢的合約，逗號分隔，統一用 "BTC/USDT" 格式
GATE_FUTURES_SYMBOLS=BTC/USDT,ETH/USDT
# 現貨要監控的幣種（留空=自動監控帳戶內所有非零餘額）
GATE_SPOT_SYMBOLS=

# ---- MEXC（合約用這組）----
MEXC_API_KEY=你的MEXC_API_Key
MEXC_API_SECRET=你的MEXC_Secret

# 輪詢間隔秒數
POLL_INTERVAL=10

# 選填：Telegram 推播通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
